# Copy to .env.local and restart the dev server after changes.

# ─── Supabase (required) ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Vercel env vars — never expose in frontend)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# RESEND_API_KEY=re_...
# RESEND_FROM=TitanOS <noreply@yourdomain.com>
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Public site URL (no trailing slash). Required for Google OAuth + Play testers.
# VITE_TITANOS_PUBLIC_ORIGIN=https://your-titanos-domain.com

# Optional direct APK URL for testers (Play is primary distribution)
# VITE_TITANOS_APK_URL=https://your-cdn.example/TitanOS.apk
