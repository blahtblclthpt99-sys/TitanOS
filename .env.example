# Copy to .env.local and restart the dev server after changes.

# ─── Supabase (required) ───────────────────────────────────────────────────────
# TitanOS is Vite (not Next.js). Use VITE_* — not NEXT_PUBLIC_*.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Legacy JWT anon key OR new sb_publishable_… key both work:
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Optional alias (same value as above):
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only (Vercel env vars — never expose in frontend)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_ACCESS_TOKEN=sbp_...   # optional; enables scripts/fix-supabase-auth.mjs
# RESEND_API_KEY=re_...
# RESEND_FROM=TitanOS <noreply@yourdomain.com>
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Public site URL (no trailing slash). Used as OAuth fallback; live host wins on web.
# VITE_TITANOS_PUBLIC_ORIGIN=https://titanos-web.vercel.app
# VITE_API_BASE_URL=https://titanos-web.vercel.app

# Google OAuth: enable in Supabase Dashboard (see GOOGLE_AUTH.md).
# Never put Google Client Secret in VITE_* vars — only in Supabase Auth settings.

# Optional direct APK URL for testers (Play is primary distribution)
# VITE_TITANOS_APK_URL=https://your-cdn.example/TitanOS.apk
